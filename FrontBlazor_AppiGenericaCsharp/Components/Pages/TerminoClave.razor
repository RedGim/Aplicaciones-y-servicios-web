@page "/terminoclave"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<PageTitle>Término Clave</PageTitle>

<div class="container mt-4">
    <h3>Término Clave</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Término Clave</button>
    }

    <div class="d-flex align-items-center mb-3">
        <label class="form-label me-2 mb-0">Limite:</label>
        <input class="form-control me-2" type="number" style="width:100px" @bind="limite" />
        <button class="btn btn-outline-secondary" @onclick="CargarRegistros">Cargar</button>
    </div>

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">
                @(editando ? "Editar Término Clave" : "Nuevo Término Clave")
            </div>

            <div class="card-body">

                <div class="row">

                    <div class="col-md-2 mb-3">
                        <label class="form-label">Término</label>
                        <input class="form-control" type="text" @bind="campoTermino" disabled="@editando"/>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label class="form-label">Término inglés</label>
                        <input class="form-control" @bind="campoTerminoIngles" />
                    </div>

                    </div>

                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>

            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary"></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">

            <thead class="table-dark">
                <tr>
                    <th>Término</th>
                    <th>Término Inglés</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>

                        <td>@reg["termino"]</td>
                        <td>@reg["termino_ingles"]</td>

                        <td>

                            <button class="btn btn-warning btn-sm me-1"
                                    @onclick="() => EditarRegistro(reg)">
                                Editar
                            </button>

                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => EliminarRegistro(reg)">
                                Eliminar
                            </button>

                        </td>

                    </tr>
                }
            </tbody>

        </table>
    }

</div>

@code {

    private List<Dictionary<string, object?>> registros = new();

    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;

    private string mensaje = "";
    private bool exito = false;

    private string campoTermino = "";

    private string campoTerminoIngles = "";

    private int? limite = null;

    protected override async Task OnInitializedAsync()
    {
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("termino_clave", limite);
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false;

        campoTermino = "";
        campoTerminoIngles = "";

        mostrarFormulario = true;
        mensaje = "";
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;

        campoTermino = reg["termino"]?.ToString() ?? "";

        campoTerminoIngles = reg["termino_ingles"]?.ToString() ?? "";

        mostrarFormulario = true;
        mensaje = "";
    }

    private async Task GuardarRegistro()
    {

        var datos = new Dictionary<string, object?>
        {
            ["termino"] = campoTermino,
            ["termino_ingles"] = campoTerminoIngles
        };

        if (editando)
        {
            datos.Remove("termino");

            var resultado = await Api.ActualizarAsync("termino_clave", "termino", campoTermino.ToString(), datos);

            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("termino_clave", datos);

            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string termino = reg["termino"]?.ToString() ?? "";

        var resultado = await Api.EliminarAsync("termino_clave", "termino", termino);

        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
            await CargarRegistros();
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = "";
    }
}
